# ── OpenRouter ──────────────────────────────────────────────
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=mistralai/mistral-7b-instruct   # free tier model

# ── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here  # service role, NOT anon

# ── App ──────────────────────────────────────────────────────
APP_ENV=development
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:5500  # add your Lovable domain too

# ── Crisis detection thresholds ──────────────────────────────
CRISIS_SCORE_THRESHOLD=0.72   # 0–1; tune this after testing
